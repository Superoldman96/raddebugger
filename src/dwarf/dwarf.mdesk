////////////////////////////////
//~ rjf: Line Info Opcodes

@table(name code params_length) DW_StdOpcodeTable:
{
  {ExtendedOpcode   0x00  0}
  {Copy             0x01  0}
  {AdvancePc        0x02  1}
  {AdvanceLine      0x03  1}
  {SetFile          0x04  1}
  {SetColumn        0x05  1}
  {NegateStmt       0x06  0}
  {SetBasicBlock    0x07  0}
  {ConstAddPc       0x08  0}
  {FixedAdvancePc   0x09  1}
  {SetPrologueEnd   0x0A  0}
  {SetEpilogueBegin 0x0B  0}
  {SetIsa           0x0C  1}
}

@enum(U8) DW_StdOpcode:
{
  @expand(DW_StdOpcodeTable a) `$(a.name) = $(a.code)`,
  COUNT
}

@xlist DW_StdOpcode_XList:
{
  @expand(DW_StdOpcodeTable a) `$(a.name), $(a.code), $(a.params_length)`
}

@table(name code) DW_ExtOpcodeTable:
{
  {Undefined        0x00}
  {EndSequence      0x01}
  {SetAddress       0x02}
  {DefineFile       0x03}
  {SetDiscriminator 0x04}
  {UserLo           0x80}
  {UserHi           0xff}
}

