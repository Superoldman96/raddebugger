@enum(U8) DW_ExprOp:
{
  @expand(DW_ExprOpTable a) `$(a.name) = $(a.code)`
}

@xlist DW_ExprOp_XList:
{
  @expand(DW_ExprOpTable a) `$(a.name), $(a.code), $(a.version), $(a.operand_count), $(a.pop_count), $(a.push_count), $(a.operand_type_0), $(a.operand_type_1), $(a.valid_for_cfa_exprs)`
}

@table(name  code  operand_count  pop_count  push_count  operand_type_0  operand_type_1  valid_for_cfa_exprs)
DW_GNU_ExprOpTable:
{
  {PushTlsAddress  0xe0   0 0 1 Null      Null  1}
  {UnInit          0xf0   0 0 0 Null      Null  1}
  {ImplicitPointer 0xf2   2 0 1 DwarfUInt SLEB128  1}
  {EntryValue      0xf3   1 0 0 Block     Null  1}
  {ConstType       0xf4   2 0 1 ULEB128   Block  1}
  {RegvalType      0xf5   2 0 1 ULEB128   ULEB128  1}
  {DerefType       0xf6   2 1 1 U8        ULEB128  1}
  {Convert         0xf7   1 1 1 ULEB128   Null  1}
  {ParameterRef    0xfa   1 0 0 U32       Null  1}
  {AddrIndex       0xfb   0 0 1 Null      Null  1}
  {ConstIndex      0xfc   1 0 1 ULEB128   Null  1}
}

@enum(U8) DW_GNU_ExprOp:
{
  @expand(DW_GNU_ExprOpTable a) `$(a.name) = $(a.code)`
}

@xlist DW_GNU_ExprOp_XList:
{
  @expand(DW_GNU_ExprOpTable a) `$(a.name), $(a.code), $(a.operand_count), $(a.pop_count), $(a.push_count), $(a.operand_type_0), $(a.operand_type_1), $(a.valid_for_cfa_exprs)`
}

