////////////////////////////////
//~ rjf: Version

@table(name)
DW_VersionTable:
{
  {Null}
  {1}
  {2}
  {3}
  {4}
  {5}
}

@enum(U16) DW_Version:
{
  @expand(DW_VersionTable a) `$(a.name)`;
  `Last = DW_Version_5`;
}

@table(name code)
DW_ExtTable:
{
  {GNU}
  {LLVM}
  {Apple}
  {MIPS}
}

@enum DW_Ext:
{
  `Null`,
  @expand(DW_ExtTable a) `$(a.name)`
}

@enum(U32) DW_ExtFlags:
{
  @expand(DW_ExtTable a) `$(a.name) = (1<<DW_Ext_$(a.name))`;
  `All = 0xffffffffu`;
}

////////////////////////////////
//~ rjf: Bit Width Setting

@table(name display_name byte_size) DW_FormatTable:
{
  {Null   ""          0}
  {32Bit  "DWARF32"   4}
  {64Bit  "DWARF64"   8}
}

@enum DW_Format:
{
  @expand(DW_FormatTable a) `$(a.name)`
}

@xlist DW_Format_XList:
{
  @expand(DW_FormatTable a) `$(a.name), "$(a.display_name)", $(a.byte_size)`
}

////////////////////////////////
//~ rjf: Sections

@table(name, regular_string, macho_string, dwo_string)
DW_SectionTable:
{
  {Null       ""                   ""                    ""                      }
  {Abbrev     ".debug_abbrev"      "__debug_abbrev"      ".debug_abbrev.dwo"     }
  {ARanges    ".debug_aranges"     "__debug_aranges"     ".debug_aranges.dwo"    }
  {Frame      ".debug_frame"       "__debug_frame"       ".debug_frame.dwo"      }
  {Info       ".debug_info"        "__debug_info"        ".debug_info.dwo"       }
  {Line       ".debug_line"        "__debug_line"        ".debug_line.dwo"       }
  {Loc        ".debug_loc"         "__debug_loc"         ".debug_loc.dwo"        }
  {MacInfo    ".debug_macinfo"     "__debug_macinfo"     ".debug_macinfo.dwo"    }
  {PubNames   ".debug_pubnames"    "__debug_pubnames"    ".debug_pubnames.dwo"   }
  {PubTypes   ".debug_pubtypes"    "__debug_pubtypes"    ".debug_pubtypes.dwo"   }
  {Ranges     ".debug_ranges"      "__debug_ranges"      ".debug_ranges.dwo"     }
  {Str        ".debug_str"         "__debug_str"         ".debug_str.dwo"        }
  {Addr       ".debug_addr"        "__debug_addr"        ".debug_addr.dwo"       }
  {LocLists   ".debug_loclists"    "__debug_loclists"    ".debug_loclists.dwo"   }
  {RngLists   ".debug_rnglists"    "__debug_rnglists"    ".debug_rnglists.dwo"   }
  {StrOffsets ".debug_str_offsets" "__debug_str_offsets" ".debug_str_offsets.dwo"}
  {LineStr    ".debug_line_str"    "__debug_line_str"    ".debug_line_str.dwo"   }
  {Names      ".debug_names"       "__debug_names"       ".debug_names.dwo"      }
}

@enum DW_SectionKind:
{
  @expand(DW_SectionTable a) `$(a.name)`,
  COUNT
}

@xlist DW_SectionKind_XList:
{
  @expand(DW_SectionTable a) `$(a.name), "$(a.regular_string)", "$(a.macho_string)", "$(a.dwo_string)"`
}

@data(String8) dw_regular_name_from_section_kind_table:
{
  @expand(DW_SectionTable a) `str8_lit_comp("$(a.regular_string)")`
}

@data(String8) dw_macho_name_from_section_kind_table:
{
  @expand(DW_SectionTable a) `str8_lit_comp("$(a.macho_string)")`
}

@data(String8) dw_dwo_name_from_section_kind_table:
{
  @expand(DW_SectionTable a) `str8_lit_comp("$(a.dwo_string)")`
}

@enum(U32) DW_SectionFlags:
{
  @expand(DW_SectionTable a) `$(a.name) = (1 << DW_SectionKind_$(a.name))`,
  `All = 0xffffffffu`;
}

