@enum DW_CFAOperandKind:
{
  Null,
  Value,
  Register,
  Expression,
}

@table(name code operand_kind_0 operand_kind_1 new_row) DW_CFAOpCodeTable:
{
  {Nop            0x0  Null             Null               0  }
  {SetLoc         0x1  Value            Null               1  }
  {AdvanceLoc1    0x2  Value            Null               1  }
  {AdvanceLoc2    0x3  Value            Null               1  }
  {AdvanceLoc4    0x4  Value            Null               1  }
  {OffsetExt      0x5  Register         Value              0  }
  {RestoreExt     0x6  Null             Null               0  }
  {Undefined      0x7  Register         Null               0  }
  {SameValue      0x8  Register         Null               0  }
  {Register       0x9  Register         Null               0  }
  {RememberState  0xa  Null             Null               0  }
  {RestoreState   0xb  Null             Null               0  }
  {DefCfa         0xc  Register         Value              0  }
  {DefCfaRegister 0xd  Register         Null               0  }
  {DefCfaOffset   0xe  Value            Null               0  }
  {DefCfaExpr     0xf  Expression       Null               0  }
  {Expr           0x10 Expression       Null               0  }
  {OffsetExtSf    0x11 Register         Value              0  }
  {DefCfaSf       0x12 Register         Value              0  }
  {DefCfaOffsetSf 0x13 Value            Null               0  }
  {ValOffset      0x14 Register         Value              0  }
  {ValOffsetSf    0x15 Register         Value              0  }
  {ValExpr        0x16 Register         Expression         0  }
  {AdvanceLoc     0x40 Value            Null               1  }
  {Offset         0x80 Register         Value              0  }
  {Restore        0xc0 Register         Null               0  }
}

